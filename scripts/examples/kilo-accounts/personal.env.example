# Kilo CLI Personal Account Configuration
# Fill in your credentials below

# Provider: openai, anthropic, google, etc.
KILO_PROVIDER=anthropic

# API Key (required) - Replace with your actual personal API key
KILO_API_KEY=sk-ant-your-personal-api-key-here

# Organization ID (optional, for Kilo Gateway)
# KILO_ORG_ID=your-personal-org-id

# Model override (optional)
KILO_MODEL=claude-sonnet-4-20250514

# Kilo Gateway model (optional, alternative to KILO_MODEL)
# KILOCODE_MODEL=anthropic/claude-sonnet-4
