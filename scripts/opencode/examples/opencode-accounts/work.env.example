# OpenCode Work Account Configuration
# Fill in credentials for providers used at work.
# Only set the keys for providers you actually need.

# ─── Provider API Keys ───────────────────────────────────────────
# Anthropic (Claude — primary work provider)
ANTHROPIC_API_KEY=sk-ant-your-work-key-here

# OpenAI (GPT — fallback / code tasks)
OPENAI_API_KEY=sk-proj-your-work-key-here

# ─── Default Routing ────────────────────────────────────────────
OPENCODE_DEFAULT_PROVIDER=anthropic
OPENCODE_DEFAULT_MODEL=claude-sonnet-4-20250514
